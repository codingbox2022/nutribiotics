# Copy to .env in the repo root (same folder as docker-compose.yml), then edit.
# docker compose reads this file for the backend container via env_file.

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nutribiotics

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

SEED_USER_EMAIL=admin@example.com
SEED_USER_PASSWORD=

OPENAI_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Do not set REDIS_URL here for Compose — docker-compose.yml forces redis://redis:6379.

# Frontend build: same-origin API via gateway nginx (default). Use an absolute URL only if you bypass the gateway.
VITE_API_BASE_URL=/api
VITE_WITH_BACKEND=true

# Published port for gateway (frontend + API on one host):
# GATEWAY_PUBLISH_PORT=80
